  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uB4F1 \uB4A4\uB97C \uC870\uC2EC\uD574\r\n\r\n[ \uAC1C\uBC1C\uD300 ]\r\n\uC870\uC9C4\uD589
    \u2014 \uD300\uC7A5 / 3\uC778\uCE6D \uD50C\uB808\uC774\uC5B4\r\n\uC548\uC815\uC5F0
    \u2014 \uB124\uD2B8\uC6CC\uD06C\r\n\uB098\uD604\uC218 \u2014 AI\r\n\uC774\uC2B9\uC5F4
    \u2014 UI/UX\r\n\uAE40\uB3D9\uD604 \u2014 \uAC8C\uC784 \uC2DC\uC2A4\uD15C\r\n\r\n[
    \uC2A4\uD398\uC15C \uB561\uC2A4 ]\r\n\uAE40\uC7AC\uC131 \uAC15\uC0AC\uB2D8, \uCD5C\uC601\uBBFC
    \uAC15\uC0AC\uB2D8, \uC774\uD0DC\uD638 \uB9E4\uB2C8\uC800\uB2D8\r\n\r\n[ \uD3F0\uD2B8
    ]\r\nBMJUA (\uBC30\uB2EC\uC758\uBBFC\uC871 \uC8FC\uC544\uCCB4) \xA9 \uC6B0\uC544\uD55C\uD615\uC81C\uB4E4\r\n\r\n[
    \uC81C\uC791 \uAE30\uAC04 ]\r\n2026.04.23 ~ 2026.05.19"
  m_isRightToLeft: 0
